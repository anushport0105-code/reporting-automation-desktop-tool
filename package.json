{
  "name": "reporting-automation-desktop-tool",
  "version": "0.6.0",
  "private": true,
  "description": "Small local Electron tool for Google search evidence capture.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "set ELECTRON_RUN_AS_NODE=& electron-vite dev",
    "build": "set ELECTRON_RUN_AS_NODE=& electron-vite build",
    "dist:win": "npm run build && electron-builder --win nsis portable --x64",
    "start": "set ELECTRON_RUN_AS_NODE=& electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.reportingautomation.desktoptool",
    "productName": "Reporting Automation",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Reporting Automation",
      "artifactName": "Reporting-Automation-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Reporting-Automation-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "lucide-react": "^0.468.0",
    "playwright": "^1.49.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.4.11",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
